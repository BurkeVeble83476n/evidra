{
  "id": "smart_lifecycle_ok",
  "steps": [
    {
      "tool": "prescribe_smart",
      "input": {
        "actor": {"type": "agent", "id": "smart-agent", "origin": "mcp"},
        "tool": "kubectl",
        "operation": "apply",
        "resource": "deployment/web",
        "namespace": "default"
      },
      "assert": {
        "ok": true,
        "has_fields": ["prescription_id", "effective_risk", "intent_digest"]
      }
    },
    {
      "tool": "report",
      "input": {
        "prescription_id": "{{prescription_id}}",
        "verdict": "success",
        "exit_code": 0,
        "actor": {"type": "agent", "id": "smart-agent", "origin": "mcp"}
      },
      "assert": {
        "ok": true,
        "has_fields": ["report_id"]
      }
    }
  ]
}
