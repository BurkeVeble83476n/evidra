{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://evidra.dev/schema/benchmark/dataset.schema.json",
  "title": "Benchmark Dataset Metadata",
  "type": "object",
  "required": [
    "dataset_version",
    "schema_version",
    "evidra_version_processed",
    "generated_at",
    "case_count",
    "dataset_label",
    "dataset_scope",
    "dataset_track",
    "dataset_not_for"
  ],
  "properties": {
    "dataset_version": {
      "type": "string",
      "minLength": 1
    },
    "schema_version": {
      "type": "string",
      "minLength": 1
    },
    "evidra_version_processed": {
      "type": "string",
      "minLength": 1
    },
    "generated_at": {
      "type": "string",
      "minLength": 1
    },
    "case_count": {
      "type": "integer",
      "minimum": 0
    },
    "dataset_label": {
      "type": "string",
      "const": "limited-contract-baseline"
    },
    "dataset_scope": {
      "type": "string",
      "const": "limited"
    },
    "dataset_track": {
      "type": "string",
      "const": "contract-validation"
    },
    "dataset_not_for": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    }
  },
  "additionalProperties": true
}
