{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://evidra.dev/schema/benchmark/expected.schema.json",
  "title": "Benchmark Case Expected Contract",
  "type": "object",
  "required": [
    "case_id",
    "dataset_label",
    "case_kind",
    "category",
    "difficulty",
    "scenario_class",
    "operation_class",
    "environment_class",
    "ground_truth_pattern",
    "artifact_ref",
    "source_refs",
    "risk_level",
    "risk_details_expected"
  ],
  "properties": {
    "case_id": {
      "type": "string",
      "minLength": 1
    },
    "dataset_label": {
      "type": "string",
      "const": "limited-contract-baseline"
    },
    "case_kind": {
      "type": "string",
      "enum": [
        "artifact",
        "pair",
        "scenario",
        "scanner",
        "hybrid"
      ]
    },
    "category": {
      "type": "string",
      "minLength": 1
    },
    "difficulty": {
      "type": "string",
      "enum": [
        "easy",
        "medium",
        "hard",
        "catastrophic"
      ]
    },
    "scenario_class": {
      "type": "string",
      "enum": [
        "safe_routine",
        "normal_mutate",
        "high_risk_ambiguous",
        "decline_worthy"
      ]
    },
    "operation_class": {
      "type": "string",
      "enum": [
        "inspect_read",
        "mutate_change",
        "deploy_rollout"
      ]
    },
    "environment_class": {
      "type": "string",
      "enum": [
        "sandbox",
        "staging",
        "prod_like"
      ]
    },
    "ground_truth_pattern": {
      "type": "string",
      "minLength": 1
    },
    "artifact_ref": {
      "type": "string",
      "pattern": "^\\.\\./\\.\\./corpus/.+"
    },
    "source_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "source_id"
        ],
        "properties": {
          "source_id": {
            "type": "string",
            "minLength": 1
          },
          "composition": {
            "type": "string"
          },
          "source_type": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    },
    "risk_level": {
      "type": "string",
      "minLength": 1
    },
    "risk_details_expected": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true
}
