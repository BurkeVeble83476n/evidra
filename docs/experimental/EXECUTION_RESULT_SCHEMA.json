{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://samebits.com/evidra-benchmark/execution-result-schema-v1.json",
  "title": "Evidra Execution Experiment Result v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "started_at",
    "finished_at",
    "duration_seconds",
    "mode",
    "model",
    "scenario",
    "execution",
    "artifacts",
    "agent_result",
    "evaluation"
  ],
  "properties": {
    "schema_version": {
      "const": "evidra.exec-result.v1"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "finished_at": {
      "type": "string",
      "format": "date-time"
    },
    "duration_seconds": {
      "type": "integer",
      "minimum": 0
    },
    "mode": {
      "type": "string",
      "enum": ["local-mcp", "local-rest", "hosted-mcp", "hosted-rest", "custom"]
    },
    "model": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "provider", "prompt_version", "repeat_index"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "provider": {"type": "string", "minLength": 1},
        "prompt_version": {"type": "string", "minLength": 1},
        "prompt_file": {"type": "string", "minLength": 1},
        "prompt_contract_version": {"type": "string", "minLength": 1},
        "repeat_index": {"type": "integer", "minimum": 1}
      }
    },
    "scenario": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "tool",
        "operation",
        "artifact_path",
        "execute_cmd"
      ],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "category": {"type": "string"},
        "difficulty": {"type": "string"},
        "tool": {"type": "string", "minLength": 1},
        "operation": {"type": "string", "minLength": 1},
        "artifact_path": {"type": "string", "minLength": 1},
        "execute_cmd": {"type": "string", "minLength": 1},
        "expected_exit_code": {"type": ["integer", "null"]},
        "expected_risk_level": {"type": "string"},
        "expected_risk_tags": {
          "type": "array",
          "items": {"type": "string"}
        },
        "source_json_path": {"type": "string", "minLength": 1}
      }
    },
    "execution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["agent_cmd", "timeout_seconds", "status", "agent_exit_code"],
      "properties": {
        "agent_cmd": {"type": "string", "minLength": 1},
        "timeout_seconds": {"type": "integer", "minimum": 1},
        "status": {"type": "string", "enum": ["success", "failure", "timeout", "dry_run"]},
        "agent_exit_code": {"type": "integer"}
      }
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["run_dir", "stdout_log", "stderr_log", "agent_output", "agent_raw_stream", "result_json"],
      "properties": {
        "run_dir": {"type": "string", "minLength": 1},
        "stdout_log": {"type": "string", "minLength": 1},
        "stderr_log": {"type": "string", "minLength": 1},
        "agent_output": {"type": "string", "minLength": 1},
        "agent_raw_stream": {"type": "string", "minLength": 1},
        "result_json": {"type": "string", "minLength": 1}
      }
    },
    "agent_result": {
      "type": "object"
    },
    "evaluation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "prescribe_ok",
        "report_ok",
        "protocol_ok",
        "command_exit_code",
        "exit_code_match",
        "observed_risk_level",
        "observed_risk_tags",
        "risk_level_match",
        "true_positive",
        "false_positive",
        "false_negative",
        "precision",
        "recall",
        "f1",
        "pass"
      ],
      "properties": {
        "prescribe_ok": {"type": "boolean"},
        "report_ok": {"type": "boolean"},
        "protocol_ok": {"type": "boolean"},
        "command_exit_code": {"type": ["integer", "null"]},
        "exit_code_match": {"type": "boolean"},
        "observed_risk_level": {"type": "string"},
        "observed_risk_tags": {
          "type": "array",
          "items": {"type": "string"}
        },
        "risk_level_match": {"type": ["boolean", "null"]},
        "true_positive": {"type": "integer", "minimum": 0},
        "false_positive": {"type": "integer", "minimum": 0},
        "false_negative": {"type": "integer", "minimum": 0},
        "precision": {"type": ["number", "null"], "minimum": 0, "maximum": 1},
        "recall": {"type": ["number", "null"], "minimum": 0, "maximum": 1},
        "f1": {"type": ["number", "null"], "minimum": 0, "maximum": 1},
        "pass": {"type": "boolean"}
      }
    }
  }
}
