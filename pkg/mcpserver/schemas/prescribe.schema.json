{
  "type": "object",
  "required": ["tool", "operation", "raw_artifact", "actor"],
  "properties": {
    "tool": {
      "type": "string",
      "description": "Infrastructure tool name (kubectl, terraform, helm, etc.)"
    },
    "operation": {
      "type": "string",
      "description": "Tool operation (apply, delete, destroy, upgrade, etc.)"
    },
    "raw_artifact": {
      "type": "string",
      "description": "Raw artifact content (YAML manifest, JSON plan, etc.)"
    },
    "canonical_action": {
      "type": "object",
      "description": "Optional pre-canonicalized action for self-aware tools",
      "properties": {
        "resource_identity": { "type": "array" },
        "resource_count": { "type": "integer" },
        "operation_class": { "type": "string" },
        "scope_class": { "type": "string" }
      }
    },
    "actor": {
      "type": "object",
      "required": ["type", "id", "origin"],
      "properties": {
        "type": { "type": "string" },
        "id": { "type": "string" },
        "origin": { "type": "string" }
      }
    },
    "actor_meta": {
      "type": "object",
      "description": "Optional comparison dimensions (agent_version, model_id, prompt_id)"
    },
    "environment": {
      "type": "string",
      "description": "Environment label (production, staging, development)"
    }
  }
}
